# ─────────────────────────────────────────────────────────────────────────────
# docker-compose environment template.
#
# Copy to `.env` at the repo root and fill in. NEVER commit this file
# with real values.
#
# Bootstrap with:
#   ./scripts/generate-secrets.sh > .env
#   echo "POSTGRES_USER=theosphere"   >> .env
#   echo "POSTGRES_DB=theosphere_db"  >> .env
# ─────────────────────────────────────────────────────────────────────────────

POSTGRES_USER=theosphere
POSTGRES_DB=theosphere_db
POSTGRES_PASSWORD=                 # required — no default

REDIS_PASSWORD=                    # optional in dev; recommended in prod

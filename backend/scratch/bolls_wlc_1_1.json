[{"pk": 2, "verse": 1, "text": "\u05d1\u05bc\u05b0\u05e8\u05b5\u05d0\u05e9\u05c1\u05b4\u0596\u05d9\u05ea \u05d1\u05bc\u05b8\u05e8\u05b8\u05a3\u05d0 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0591\u05d9\u05dd \u05d0\u05b5\u05a5\u05ea \u05d4\u05b7\u05e9\u05c1\u05bc\u05b8\u05de\u05b7\u0596\u05d9\u05b4\u05dd \u05d5\u05b0\u05d0\u05b5\u05a5\u05ea \u05d4\u05b8\u05d0\u05b8\u05bd\u05e8\u05b6\u05e5\u05c3"}, {"pk": 3, "verse": 2, "text": "\u05d5\u05b0\u05d4\u05b8\u05d0\u05b8\u0597\u05e8\u05b6\u05e5 \u05d4\u05b8\u05d9\u05b0\u05ea\u05b8\u05a5\u05d4 \u05ea\u05b9\u0599\u05d4\u05d5\u05bc\u0599 \u05d5\u05b8\u05d1\u05b9\u0594\u05d4\u05d5\u05bc \u05d5\u05b0\u05d7\u05b9\u0596\u05e9\u05c1\u05b6\u05da\u05b0 \u05e2\u05b7\u05dc\u05be\u05e4\u05bc\u05b0\u05e0\u05b5\u05a3\u05d9 \u05ea\u05b0\u05d4\u05b9\u0591\u05d5\u05dd \u05d5\u05b0\u05e8\u05a3\u05d5\u05bc\u05d7\u05b7 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0594\u05d9\u05dd \u05de\u05b0\u05e8\u05b7\u05d7\u05b6\u0596\u05e4\u05b6\u05ea \u05e2\u05b7\u05dc\u05be\u05e4\u05bc\u05b0\u05e0\u05b5\u05a5\u05d9 \u05d4\u05b7\u05de\u05bc\u05b8\u05bd\u05d9\u05b4\u05dd\u05c3"}, {"pk": 4, "verse": 3, "text": "\u05d5\u05b7\u05d9\u05bc\u05b9\u05a5\u05d0\u05de\u05b6\u05e8 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0596\u05d9\u05dd \u05d9\u05b0\u05d4\u05b4\u05a3\u05d9 \u05d0\u05b9\u0591\u05d5\u05e8 \u05d5\u05b7\u05bd\u05d9\u05b0\u05d4\u05b4\u05d9\u05be\u05d0\u05b9\u05bd\u05d5\u05e8\u05c3"}, {"pk": 5, "verse": 4, "text": "\u05d5\u05b7\u05d9\u05bc\u05b7\u05a7\u05e8\u05b0\u05d0 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u059b\u05d9\u05dd \u05d0\u05b6\u05ea\u05be\u05d4\u05b8\u05d0\u05b9\u0596\u05d5\u05e8 \u05db\u05bc\u05b4\u05d9\u05be\u05d8\u05b9\u0591\u05d5\u05d1 \u05d5\u05b7\u05d9\u05bc\u05b7\u05d1\u05b0\u05d3\u05bc\u05b5\u05a3\u05dc \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0594\u05d9\u05dd \u05d1\u05bc\u05b5\u05a5\u05d9\u05df \u05d4\u05b8\u05d0\u05b9\u0596\u05d5\u05e8 \u05d5\u05bc\u05d1\u05b5\u05a5\u05d9\u05df \u05d4\u05b7\u05d7\u05b9\u05bd\u05e9\u05c1\u05b6\u05da\u05b0\u05c3"}, {"pk": 6, "verse": 5, "text": "\u05d5\u05b7\u05d9\u05bc\u05b4\u05e7\u05b0\u05e8\u05b8\u05a8\u05d0 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u05a4\u05d9\u05dd \u05c0 \u05dc\u05b8\u05d0\u05b9\u05d5\u05e8\u0599 \u05d9\u05b9\u0594\u05d5\u05dd \u05d5\u05b0\u05dc\u05b7\u05d7\u05b9\u0596\u05e9\u05c1\u05b6\u05da\u05b0 \u05e7\u05b8\u05a3\u05e8\u05b8\u05d0 \u05dc\u05b8\u0591\u05d9\u05b0\u05dc\u05b8\u05d4 \u05d5\u05b7\u05bd\u05d9\u05b0\u05d4\u05b4\u05d9\u05be\u05e2\u05b6\u05a5\u05e8\u05b6\u05d1 \u05d5\u05b7\u05bd\u05d9\u05b0\u05d4\u05b4\u05d9\u05be\u05d1\u05b9\u0596\u05e7\u05b6\u05e8 \u05d9\u05b9\u05a5\u05d5\u05dd \u05d0\u05b6\u05d7\u05b8\u05bd\u05d3\u05c3  \u05e4"}, {"pk": 7, "verse": 6, "text": "\u05d5\u05b7\u05d9\u05bc\u05b9\u05a3\u05d0\u05de\u05b6\u05e8 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0594\u05d9\u05dd \u05d9\u05b0\u05d4\u05b4\u05a5\u05d9 \u05e8\u05b8\u05e7\u05b4\u0596\u05d9\u05e2\u05b7 \u05d1\u05bc\u05b0\u05ea\u05b9\u05a3\u05d5\u05da\u05b0 \u05d4\u05b7\u05de\u05bc\u05b8\u0591\u05d9\u05b4\u05dd \u05d5\u05b4\u05d9\u05d4\u05b4\u05a3\u05d9 \u05de\u05b7\u05d1\u05b0\u05d3\u05bc\u05b4\u0594\u05d9\u05dc \u05d1\u05bc\u05b5\u05a5\u05d9\u05df \u05de\u05b7\u0596\u05d9\u05b4\u05dd \u05dc\u05b8\u05de\u05b8\u05bd\u05d9\u05b4\u05dd\u05c3"}, {"pk": 8, "verse": 7, "text": "\u05d5\u05b7\u05d9\u05bc\u05b7\u05a3\u05e2\u05b7\u05e9\u05c2 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u05d9\u05dd\u05ae \u05d0\u05b6\u05ea\u05be\u05d4\u05b8\u05e8\u05b8\u05e7\u05b4\u05d9\u05e2\u05b7\u0592 \u05d5\u05b7\u05d9\u05bc\u05b7\u05d1\u05b0\u05d3\u05bc\u05b5\u0597\u05dc \u05d1\u05bc\u05b5\u05a4\u05d9\u05df \u05d4\u05b7\u05de\u05bc\u05b7\u0599\u05d9\u05b4\u05dd\u0599 \u05d0\u05b2\u05e9\u05c1\u05b6\u05e8\u0599 \u05de\u05b4\u05ea\u05bc\u05b7\u05a3\u05d7\u05b7\u05ea \u05dc\u05b8\u05e8\u05b8\u05e7\u05b4\u0594\u05d9\u05e2\u05b7 \u05d5\u05bc\u05d1\u05b5\u05a3\u05d9\u05df \u05d4\u05b7\u05de\u05bc\u05b7\u0594\u05d9\u05b4\u05dd \u05d0\u05b2\u05e9\u05c1\u05b6\u0596\u05e8 \u05de\u05b5\u05e2\u05b7\u05a3\u05dc \u05dc\u05b8\u05e8\u05b8\u05e7\u05b4\u0591\u05d9\u05e2\u05b7 \u05d5\u05b7\u05bd\u05d9\u05b0\u05d4\u05b4\u05d9\u05be\u05db\u05b5\u05bd\u05df\u05c3"}, {"pk": 9, "verse": 8, "text": "\u05d5\u05b7\u05d9\u05bc\u05b4\u05e7\u05b0\u05e8\u05b8\u05a7\u05d0 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u059b\u05d9\u05dd \u05dc\u05b8\u05bd\u05e8\u05b8\u05e7\u05b4\u0596\u05d9\u05e2\u05b7 \u05e9\u05c1\u05b8\u05de\u05b8\u0591\u05d9\u05b4\u05dd \u05d5\u05b7\u05bd\u05d9\u05b0\u05d4\u05b4\u05d9\u05be\u05e2\u05b6\u05a5\u05e8\u05b6\u05d1 \u05d5\u05b7\u05bd\u05d9\u05b0\u05d4\u05b4\u05d9\u05be\u05d1\u05b9\u0596\u05e7\u05b6\u05e8 \u05d9\u05b9\u05a5\u05d5\u05dd \u05e9\u05c1\u05b5\u05e0\u05b4\u05bd\u05d9\u05c3  \u05e4"}, {"pk": 10, "verse": 9, "text": "\u05d5\u05b7\u05d9\u05bc\u05b9\u05a3\u05d0\u05de\u05b6\u05e8 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0597\u05d9\u05dd \u05d9\u05b4\u05e7\u05bc\u05b8\u05d5\u05a8\u05d5\u05bc \u05d4\u05b7\u05de\u05bc\u05b7\u059c\u05d9\u05b4\u05dd \u05de\u05b4\u05ea\u05bc\u05b7\u05a4\u05d7\u05b7\u05ea \u05d4\u05b7\u05e9\u05c1\u05bc\u05b8\u05de\u05b7\u0599\u05d9\u05b4\u05dd\u0599 \u05d0\u05b6\u05dc\u05be\u05de\u05b8\u05e7\u05b9\u05a3\u05d5\u05dd \u05d0\u05b6\u05d7\u05b8\u0594\u05d3 \u05d5\u05b0\u05ea\u05b5\u05e8\u05b8\u05d0\u05b6\u0596\u05d4 \u05d4\u05b7\u05d9\u05bc\u05b7\u05d1\u05bc\u05b8\u05e9\u05c1\u05b8\u0591\u05d4 \u05d5\u05b7\u05bd\u05d9\u05b0\u05d4\u05b4\u05d9\u05be\u05db\u05b5\u05bd\u05df\u05c3"}, {"pk": 11, "verse": 10, "text": "\u05d5\u05b7\u05d9\u05bc\u05b4\u05e7\u05b0\u05e8\u05b8\u05a8\u05d0 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u05a4\u05d9\u05dd \u05c0 \u05dc\u05b7\u05d9\u05bc\u05b7\u05d1\u05bc\u05b8\u05e9\u05c1\u05b8\u05d4\u0599 \u05d0\u05b6\u0594\u05e8\u05b6\u05e5 \u05d5\u05bc\u05dc\u05b0\u05de\u05b4\u05e7\u05b0\u05d5\u05b5\u05a5\u05d4 \u05d4\u05b7\u05de\u05bc\u05b7\u0596\u05d9\u05b4\u05dd \u05e7\u05b8\u05e8\u05b8\u05a3\u05d0 \u05d9\u05b7\u05de\u05bc\u05b4\u0591\u05d9\u05dd \u05d5\u05b7\u05d9\u05bc\u05b7\u05a5\u05e8\u05b0\u05d0 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0596\u05d9\u05dd \u05db\u05bc\u05b4\u05d9\u05be\u05d8\u05b9\u05bd\u05d5\u05d1\u05c3"}, {"pk": 12, "verse": 11, "text": "\u05d5\u05b7\u05d9\u05bc\u05b9\u05a3\u05d0\u05de\u05b6\u05e8 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0597\u05d9\u05dd \u05ea\u05bc\u05b7\u05bd\u05d3\u05b0\u05e9\u05c1\u05b5\u05a4\u05d0 \u05d4\u05b8\u05d0\u05b8\u0599\u05e8\u05b6\u05e5\u0599 \u05d3\u05bc\u05b6\u0594\u05e9\u05c1\u05b6\u05d0 \u05e2\u05b5\u059a\u05e9\u05c2\u05b6\u05d1 \u05de\u05b7\u05d6\u05b0\u05e8\u05b4\u05a3\u05d9\u05e2\u05b7 \u05d6\u05b6\u0594\u05e8\u05b7\u05e2 \u05e2\u05b5\u05a3\u05e5 \u05e4\u05bc\u05b0\u05e8\u05b4\u059e\u05d9 \u05e2\u05b9\u05a4\u05e9\u05c2\u05b6\u05d4 \u05e4\u05bc\u05b0\u05e8\u05b4\u05d9\u0599 \u05dc\u05b0\u05de\u05b4\u05d9\u05e0\u05b9\u0594\u05d5 \u05d0\u05b2\u05e9\u05c1\u05b6\u05a5\u05e8 \u05d6\u05b7\u05e8\u05b0\u05e2\u05b9\u05d5\u05be\u05d1\u05b9\u0596\u05d5 \u05e2\u05b7\u05dc\u05be\u05d4\u05b8\u05d0\u05b8\u0591\u05e8\u05b6\u05e5 \u05d5\u05b7\u05bd\u05d9\u05b0\u05d4\u05b4\u05d9\u05be\u05db\u05b5\u05bd\u05df\u05c3"}, {"pk": 13, "verse": 12, "text": "\u05d5\u05b7\u05ea\u05bc\u05b9\u05d5\u05e6\u05b5\u05a8\u05d0 \u05d4\u05b8\u05d0\u05b8\u059c\u05e8\u05b6\u05e5 \u05d3\u05bc\u05b6\u05a0\u05e9\u05c1\u05b6\u05d0 \u05e2\u05b5\u05a3\u05e9\u05c2\u05b6\u05d1 \u05de\u05b7\u05d6\u05b0\u05e8\u05b4\u05a4\u05d9\u05e2\u05b7 \u05d6\u05b6\u0599\u05e8\u05b7\u05e2\u0599 \u05dc\u05b0\u05de\u05b4\u05d9\u05e0\u05b5\u0594\u05d4\u05d5\u05bc \u05d5\u05b0\u05e2\u05b5\u05a7\u05e5 \u05e2\u05b9\u05bd\u05e9\u05c2\u05b6\u05d4\u05be\u05e4\u05bc\u05b0\u05e8\u05b4\u059b\u05d9  \u05d0\u05b2\u05e9\u05c1\u05b6\u05a5\u05e8 \u05d6\u05b7\u05e8\u05b0\u05e2\u05b9\u05d5\u05be\u05d1\u05b9\u0596\u05d5 \u05dc\u05b0\u05de\u05b4\u05d9\u05e0\u05b5\u0591\u05d4\u05d5\u05bc \u05d5\u05b7\u05d9\u05bc\u05b7\u05a5\u05e8\u05b0\u05d0 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0596\u05d9\u05dd \u05db\u05bc\u05b4\u05d9\u05be\u05d8\u05b9\u05bd\u05d5\u05d1\u05c3"}, {"pk": 14, "verse": 13, "text": "\u05d5\u05bd\u05b7\u05d9\u05b0\u05d4\u05b4\u05d9\u05be\u05e2\u05b6\u05a5\u05e8\u05b6\u05d1 \u05d5\u05bd\u05b7\u05d9\u05b0\u05d4\u05b4\u05d9\u05be\u05d1\u05b9\u0596\u05e7\u05b6\u05e8 \u05d9\u05b9\u05a5\u05d5\u05dd \u05e9\u05c1\u05b0\u05dc\u05b4\u05d9\u05e9\u05c1\u05b4\u05bd\u05d9\u05c3  \u05e4"}, {"pk": 15, "verse": 14, "text": "\u05d5\u05b7\u05d9\u05bc\u05b9\u05a3\u05d0\u05de\u05b6\u05e8 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0597\u05d9\u05dd \u05d9\u05b0\u05d4\u05b4\u05a4\u05d9 \u05de\u05b0\u05d0\u05b9\u05e8\u05b9\u05ea\u0599 \u05d1\u05bc\u05b4\u05e8\u05b0\u05e7\u05b4\u05a3\u05d9\u05e2\u05b7 \u05d4\u05b7\u05e9\u05c1\u05bc\u05b8\u05de\u05b7\u0594\u05d9\u05b4\u05dd \u05dc\u05b0\u05d4\u05b7\u05d1\u05b0\u05d3\u05bc\u05b4\u0595\u05d9\u05dc \u05d1\u05bc\u05b5\u05a5\u05d9\u05df \u05d4\u05b7\u05d9\u05bc\u05b9\u0596\u05d5\u05dd \u05d5\u05bc\u05d1\u05b5\u05a3\u05d9\u05df \u05d4\u05b7\u05dc\u05bc\u05b8\u0591\u05d9\u05b0\u05dc\u05b8\u05d4 \u05d5\u05b0\u05d4\u05b8\u05d9\u05a4\u05d5\u05bc \u05dc\u05b0\u05d0\u05b9\u05ea\u05b9\u05ea\u0599 \u05d5\u05bc\u05dc\u05b0\u05de\u05b9\u05a3\u05d5\u05e2\u05b2\u05d3\u05b4\u0594\u05d9\u05dd \u05d5\u05bc\u05dc\u05b0\u05d9\u05b8\u05de\u05b4\u0596\u05d9\u05dd \u05d5\u05b0\u05e9\u05c1\u05b8\u05e0\u05b4\u05bd\u05d9\u05dd\u05c3"}, {"pk": 16, "verse": 15, "text": "\u05d5\u05b0\u05d4\u05b8\u05d9\u05a4\u05d5\u05bc \u05dc\u05b4\u05de\u05b0\u05d0\u05b9\u05d5\u05e8\u05b9\u05ea\u0599 \u05d1\u05bc\u05b4\u05e8\u05b0\u05e7\u05b4\u05a3\u05d9\u05e2\u05b7 \u05d4\u05b7\u05e9\u05c1\u05bc\u05b8\u05de\u05b7\u0594\u05d9\u05b4\u05dd \u05dc\u05b0\u05d4\u05b8\u05d0\u05b4\u0596\u05d9\u05e8 \u05e2\u05b7\u05dc\u05be\u05d4\u05b8\u05d0\u05b8\u0591\u05e8\u05b6\u05e5 \u05d5\u05bd\u05b7\u05d9\u05b0\u05d4\u05b4\u05d9\u05be\u05db\u05b5\u05bd\u05df\u05c3"}, {"pk": 17, "verse": 16, "text": "\u05d5\u05b7\u05d9\u05bc\u05b7\u05a3\u05e2\u05b7\u05e9\u05c2 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0594\u05d9\u05dd \u05d0\u05b6\u05ea\u05be\u05e9\u05c1\u05b0\u05e0\u05b5\u05a5\u05d9 \u05d4\u05b7\u05de\u05bc\u05b0\u05d0\u05b9\u05e8\u05b9\u0596\u05ea \u05d4\u05b7\u05d2\u05bc\u05b0\u05d3\u05b9\u05dc\u05b4\u0591\u05d9\u05dd \u05d0\u05b6\u05ea\u05be\u05d4\u05b7\u05de\u05bc\u05b8\u05d0\u05b9\u05a4\u05d5\u05e8 \u05d4\u05b7\u05d2\u05bc\u05b8\u05d3\u05b9\u05dc\u0599 \u05dc\u05b0\u05de\u05b6\u05de\u05b0\u05e9\u05c1\u05b6\u05a3\u05dc\u05b6\u05ea \u05d4\u05b7\u05d9\u05bc\u05b9\u0594\u05d5\u05dd \u05d5\u05b0\u05d0\u05b6\u05ea\u05be\u05d4\u05b7\u05de\u05bc\u05b8\u05d0\u05b9\u05a4\u05d5\u05e8 \u05d4\u05b7\u05e7\u05bc\u05b8\u05d8\u05b9\u05df\u0599 \u05dc\u05b0\u05de\u05b6\u05de\u05b0\u05e9\u05c1\u05b6\u05a3\u05dc\u05b6\u05ea \u05d4\u05b7\u05dc\u05bc\u05b7\u0594\u05d9\u05b0\u05dc\u05b8\u05d4 \u05d5\u05b0\u05d0\u05b5\u0596\u05ea \u05d4\u05b7\u05db\u05bc\u05b9\u05d5\u05db\u05b8\u05d1\u05b4\u05bd\u05d9\u05dd\u05c3"}, {"pk": 18, "verse": 17, "text": "\u05d5\u05b7\u05d9\u05bc\u05b4\u05ea\u05bc\u05b5\u05a5\u05df \u05d0\u05b9\u05ea\u05b8\u059b\u05dd \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0596\u05d9\u05dd \u05d1\u05bc\u05b4\u05e8\u05b0\u05e7\u05b4\u05a3\u05d9\u05e2\u05b7 \u05d4\u05b7\u05e9\u05c1\u05bc\u05b8\u05de\u05b8\u0591\u05d9\u05b4\u05dd \u05dc\u05b0\u05d4\u05b8\u05d0\u05b4\u0596\u05d9\u05e8 \u05e2\u05b7\u05dc\u05be\u05d4\u05b8\u05d0\u05b8\u05bd\u05e8\u05b6\u05e5\u05c3"}, {"pk": 19, "verse": 18, "text": "\u05d5\u05b0\u05dc\u05b4\u05de\u05b0\u05e9\u05c1\u05b9\u05dc\u0599 \u05d1\u05bc\u05b7\u05d9\u05bc\u05b9\u05a3\u05d5\u05dd \u05d5\u05bc\u05d1\u05b7\u05dc\u05bc\u05b7\u0594\u05d9\u05b0\u05dc\u05b8\u05d4 \u05d5\u05bc\u05bd\u05dc\u05b2\u05d4\u05b7\u05d1\u05b0\u05d3\u05bc\u05b4\u0594\u05d9\u05dc \u05d1\u05bc\u05b5\u05a5\u05d9\u05df \u05d4\u05b8\u05d0\u05b9\u0596\u05d5\u05e8 \u05d5\u05bc\u05d1\u05b5\u05a3\u05d9\u05df \u05d4\u05b7\u05d7\u05b9\u0591\u05e9\u05c1\u05b6\u05da\u05b0 \u05d5\u05b7\u05d9\u05bc\u05b7\u05a5\u05e8\u05b0\u05d0 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0596\u05d9\u05dd \u05db\u05bc\u05b4\u05d9\u05be\u05d8\u05b9\u05bd\u05d5\u05d1\u05c3"}, {"pk": 20, "verse": 19, "text": "\u05d5\u05b7\u05bd\u05d9\u05b0\u05d4\u05b4\u05d9\u05be\u05e2\u05b6\u05a5\u05e8\u05b6\u05d1 \u05d5\u05b7\u05bd\u05d9\u05b0\u05d4\u05b4\u05d9\u05be\u05d1\u05b9\u0596\u05e7\u05b6\u05e8 \u05d9\u05b9\u05a5\u05d5\u05dd \u05e8\u05b0\u05d1\u05b4\u05d9\u05e2\u05b4\u05bd\u05d9\u05c3  \u05e4"}, {"pk": 21, "verse": 20, "text": "\u05d5\u05b7\u05d9\u05bc\u05b9\u05a3\u05d0\u05de\u05b6\u05e8 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0594\u05d9\u05dd \u05d9\u05b4\u05e9\u05c1\u05b0\u05e8\u05b0\u05e6\u05a3\u05d5\u05bc \u05d4\u05b7\u05de\u05bc\u05b7\u0594\u05d9\u05b4\u05dd \u05e9\u05c1\u05b6\u0596\u05e8\u05b6\u05e5 \u05e0\u05b6\u05a3\u05e4\u05b6\u05e9\u05c1 \u05d7\u05b7\u05d9\u05bc\u05b8\u0591\u05d4 \u05d5\u05b0\u05e2\u05b9\u05d5\u05e3\u0599 \u05d9\u05b0\u05e2\u05b9\u05d5\u05e4\u05b5\u05a3\u05e3 \u05e2\u05b7\u05dc\u05be\u05d4\u05b8\u05d0\u05b8\u0594\u05e8\u05b6\u05e5 \u05e2\u05b7\u05dc\u05be\u05e4\u05bc\u05b0\u05e0\u05b5\u0596\u05d9 \u05e8\u05b0\u05e7\u05b4\u05a5\u05d9\u05e2\u05b7 \u05d4\u05b7\u05e9\u05c1\u05bc\u05b8\u05de\u05b8\u05bd\u05d9\u05b4\u05dd\u05c3"}, {"pk": 22, "verse": 21, "text": "\u05d5\u05b7\u05d9\u05bc\u05b4\u05d1\u05b0\u05e8\u05b8\u05a3\u05d0 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0594\u05d9\u05dd \u05d0\u05b6\u05ea\u05be\u05d4\u05b7\u05ea\u05bc\u05b7\u05e0\u05bc\u05b4\u05d9\u05e0\u05b4\u0596\u05dd \u05d4\u05b7\u05d2\u05bc\u05b0\u05d3\u05b9\u05dc\u05b4\u0591\u05d9\u05dd \u05d5\u05b0\u05d0\u05b5\u05a3\u05ea \u05db\u05bc\u05b8\u05dc\u05be\u05e0\u05b6\u05a3\u05e4\u05b6\u05e9\u05c1 \u05d4\u05bd\u05b7\u05d7\u05b7\u05d9\u05bc\u05b8\u05a3\u05d4 \u05c0 \u05d4\u05b8\u05bd\u05e8\u05b9\u05de\u05b6\u05a1\u05e9\u05c2\u05b6\u05ea \u05d0\u05b2\u05e9\u05c1\u05b6\u05e8\u05a9 \u05e9\u05c1\u05b8\u05e8\u05b0\u05e6\u05a8\u05d5\u05bc \u05d4\u05b7\u05de\u05bc\u05b7\u059c\u05d9\u05b4\u05dd \u05dc\u05b0\u05de\u05b4\u05bd\u05d9\u05e0\u05b5\u05d4\u05b6\u0597\u05dd \u05d5\u05b0\u05d0\u05b5\u05a8\u05ea \u05db\u05bc\u05b8\u05dc\u05be\u05e2\u05b9\u05a4\u05d5\u05e3 \u05db\u05bc\u05b8\u05e0\u05b8\u05e3\u0599 \u05dc\u05b0\u05de\u05b4\u05d9\u05e0\u05b5\u0594\u05d4\u05d5\u05bc \u05d5\u05b7\u05d9\u05bc\u05b7\u05a5\u05e8\u05b0\u05d0 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0596\u05d9\u05dd \u05db\u05bc\u05b4\u05d9\u05be\u05d8\u05b9\u05bd\u05d5\u05d1\u05c3"}, {"pk": 23, "verse": 22, "text": "\u05d5\u05b7\u05d9\u05b0\u05d1\u05b8\u05a7\u05e8\u05b6\u05da\u05b0 \u05d0\u05b9\u05ea\u05b8\u059b\u05dd \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0596\u05d9\u05dd \u05dc\u05b5\u05d0\u05de\u05b9\u0591\u05e8 \u05e4\u05bc\u05b0\u05e8\u05a3\u05d5\u05bc \u05d5\u05bc\u05e8\u05b0\u05d1\u0597\u05d5\u05bc \u05d5\u05bc\u05de\u05b4\u05dc\u05b0\u05d0\u05a4\u05d5\u05bc \u05d0\u05b6\u05ea\u05be\u05d4\u05b7\u05de\u05bc\u05b7\u0599\u05d9\u05b4\u05dd\u0599 \u05d1\u05bc\u05b7\u05d9\u05bc\u05b7\u05de\u05bc\u05b4\u0594\u05d9\u05dd \u05d5\u05b0\u05d4\u05b8\u05e2\u05b9\u0596\u05d5\u05e3 \u05d9\u05b4\u05a5\u05e8\u05b6\u05d1 \u05d1\u05bc\u05b8\u05d0\u05b8\u05bd\u05e8\u05b6\u05e5\u05c3"}, {"pk": 24, "verse": 23, "text": "\u05d5\u05b7\u05bd\u05d9\u05b0\u05d4\u05b4\u05d9\u05be\u05e2\u05b6\u05a5\u05e8\u05b6\u05d1 \u05d5\u05b7\u05bd\u05d9\u05b0\u05d4\u05b4\u05d9\u05be\u05d1\u05b9\u0596\u05e7\u05b6\u05e8 \u05d9\u05b9\u05a5\u05d5\u05dd \u05d7\u05b2\u05de\u05b4\u05d9\u05e9\u05c1\u05b4\u05bd\u05d9\u05c3  \u05e4"}, {"pk": 25, "verse": 24, "text": "\u05d5\u05b7\u05d9\u05bc\u05b9\u05a3\u05d0\u05de\u05b6\u05e8 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0597\u05d9\u05dd \u05ea\u05bc\u05b9\u05d5\u05e6\u05b5\u05a8\u05d0 \u05d4\u05b8\u05d0\u05b8\u059c\u05e8\u05b6\u05e5 \u05e0\u05b6\u05a4\u05e4\u05b6\u05e9\u05c1 \u05d7\u05b7\u05d9\u05bc\u05b8\u05d4\u0599 \u05dc\u05b0\u05de\u05b4\u05d9\u05e0\u05b8\u0594\u05d4\u05bc \u05d1\u05bc\u05b0\u05d4\u05b5\u05de\u05b8\u05a5\u05d4 \u05d5\u05b8\u05e8\u05b6\u059b\u05de\u05b6\u05e9\u05c2 \u05d5\u05b0\u05d7\u05b7\u05bd\u05d9\u05b0\u05ea\u05b9\u05d5\u05be\u05d0\u05b6\u0596\u05e8\u05b6\u05e5 \u05dc\u05b0\u05de\u05b4\u05d9\u05e0\u05b8\u0591\u05d4\u05bc \u05d5\u05b7\u05bd\u05d9\u05b0\u05d4\u05b4\u05d9\u05be\u05db\u05b5\u05bd\u05df\u05c3"}, {"pk": 26, "verse": 25, "text": "\u05d5\u05b7\u05d9\u05bc\u05b7\u05a3\u05e2\u05b7\u05e9\u05c2 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u05d9\u05dd\u05a9 \u05d0\u05b6\u05ea\u05be\u05d7\u05b7\u05d9\u05bc\u05b7\u05a8\u05ea \u05d4\u05b8\u05d0\u05b8\u059c\u05e8\u05b6\u05e5 \u05dc\u05b0\u05de\u05b4\u05d9\u05e0\u05b8\u0597\u05d4\u05bc \u05d5\u05b0\u05d0\u05b6\u05ea\u05be\u05d4\u05b7\u05d1\u05bc\u05b0\u05d4\u05b5\u05de\u05b8\u05d4\u0599 \u05dc\u05b0\u05de\u05b4\u05d9\u05e0\u05b8\u0594\u05d4\u05bc \u05d5\u05b0\u05d0\u05b5\u059b\u05ea \u05db\u05bc\u05b8\u05dc\u05be\u05e8\u05b6\u05a5\u05de\u05b6\u05e9\u05c2 \u05d4\u05b8\u05bd\u05d0\u05b2\u05d3\u05b8\u05de\u05b8\u0596\u05d4 \u05dc\u05b0\u05de\u05b4\u05d9\u05e0\u05b5\u0591\u05d4\u05d5\u05bc \u05d5\u05b7\u05d9\u05bc\u05b7\u05a5\u05e8\u05b0\u05d0 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0596\u05d9\u05dd \u05db\u05bc\u05b4\u05d9\u05be\u05d8\u05b9\u05bd\u05d5\u05d1\u05c3"}, {"pk": 27, "verse": 26, "text": "\u05d5\u05b7\u05d9\u05bc\u05b9\u05a3\u05d0\u05de\u05b6\u05e8 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0594\u05d9\u05dd \u05e0\u05b7\u05bd\u05e2\u05b2\u05e9\u05c2\u05b6\u05a5\u05d4 \u05d0\u05b8\u05d3\u05b8\u059b\u05dd \u05d1\u05bc\u05b0\u05e6\u05b7\u05dc\u05b0\u05de\u05b5\u0596\u05e0\u05d5\u05bc \u05db\u05bc\u05b4\u05d3\u05b0\u05de\u05d5\u05bc\u05ea\u05b5\u0591\u05e0\u05d5\u05bc \u05d5\u05b0\u05d9\u05b4\u05e8\u05b0\u05d3\u05bc\u05d5\u05bc\u05a9 \u05d1\u05b4\u05d3\u05b0\u05d2\u05b7\u05a8\u05ea \u05d4\u05b7\u05d9\u05bc\u05b8\u059c\u05dd \u05d5\u05bc\u05d1\u05b0\u05e2\u05b9\u05a3\u05d5\u05e3 \u05d4\u05b7\u05e9\u05c1\u05bc\u05b8\u05de\u05b7\u0597\u05d9\u05b4\u05dd \u05d5\u05bc\u05d1\u05b7\u05d1\u05bc\u05b0\u05d4\u05b5\u05de\u05b8\u05d4\u0599 \u05d5\u05bc\u05d1\u05b0\u05db\u05b8\u05dc\u05be\u05d4\u05b8\u05d0\u05b8\u0594\u05e8\u05b6\u05e5 \u05d5\u05bc\u05d1\u05b0\u05db\u05b8\u05dc\u05be\u05d4\u05b8\u05e8\u05b6\u0596\u05de\u05b6\u05e9\u05c2 \u05d4\u05bd\u05b8\u05e8\u05b9\u05de\u05b5\u05a5\u05e9\u05c2 \u05e2\u05b7\u05dc\u05be\u05d4\u05b8\u05d0\u05b8\u05bd\u05e8\u05b6\u05e5\u05c3"}, {"pk": 28, "verse": 27, "text": "\u05d5\u05b7\u05d9\u05bc\u05b4\u05d1\u05b0\u05e8\u05b8\u05a8\u05d0 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u05a4\u05d9\u05dd \u05c0 \u05d0\u05b6\u05ea\u05be\u05d4\u05bd\u05b8\u05d0\u05b8\u05d3\u05b8\u05dd\u0599 \u05d1\u05bc\u05b0\u05e6\u05b7\u05dc\u05b0\u05de\u05b9\u0594\u05d5 \u05d1\u05bc\u05b0\u05e6\u05b6\u05a5\u05dc\u05b6\u05dd \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0596\u05d9\u05dd \u05d1\u05bc\u05b8\u05e8\u05b8\u05a3\u05d0 \u05d0\u05b9\u05ea\u05b9\u0591\u05d5 \u05d6\u05b8\u05db\u05b8\u05a5\u05e8 \u05d5\u05bc\u05e0\u05b0\u05e7\u05b5\u05d1\u05b8\u0596\u05d4 \u05d1\u05bc\u05b8\u05e8\u05b8\u05a5\u05d0 \u05d0\u05b9\u05ea\u05b8\u05bd\u05dd\u05c3"}, {"pk": 29, "verse": 28, "text": "\u05d5\u05b7\u05d9\u05b0\u05d1\u05b8\u05a3\u05e8\u05b6\u05da\u05b0 \u05d0\u05b9\u05ea\u05b8\u05dd\u05ae \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u05d9\u05dd\u0592 \u05d5\u05b7\u05d9\u05bc\u05b9\u05a8\u05d0\u05de\u05b6\u05e8 \u05dc\u05b8\u05d4\u05b6\u059c\u05dd \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0597\u05d9\u05dd \u05e4\u05bc\u05b0\u05e8\u05a5\u05d5\u05bc \u05d5\u05bc\u05e8\u05b0\u05d1\u059b\u05d5\u05bc \u05d5\u05bc\u05de\u05b4\u05dc\u05b0\u05d0\u05a5\u05d5\u05bc \u05d0\u05b6\u05ea\u05be\u05d4\u05b8\u05d0\u05b8\u0596\u05e8\u05b6\u05e5 \u05d5\u05b0\u05db\u05b4\u05d1\u05b0\u05e9\u05c1\u05bb\u0591\u05d4\u05b8 \u05d5\u05bc\u05e8\u05b0\u05d3\u059e\u05d5\u05bc \u05d1\u05bc\u05b4\u05d3\u05b0\u05d2\u05b7\u05a4\u05ea \u05d4\u05b7\u05d9\u05bc\u05b8\u05dd\u0599 \u05d5\u05bc\u05d1\u05b0\u05e2\u05b9\u05a3\u05d5\u05e3 \u05d4\u05b7\u05e9\u05c1\u05bc\u05b8\u05de\u05b7\u0594\u05d9\u05b4\u05dd \u05d5\u05bc\u05d1\u05b0\u05db\u05b8\u05dc\u05be\u05d7\u05b7\u05d9\u05bc\u05b8\u0596\u05d4 \u05d4\u05bd\u05b8\u05e8\u05b9\u05de\u05b6\u05a5\u05e9\u05c2\u05b6\u05ea \u05e2\u05b7\u05dc\u05be\u05d4\u05b8\u05d0\u05b8\u05bd\u05e8\u05b6\u05e5\u05c3"}, {"pk": 30, "verse": 29, "text": "\u05d5\u05b7\u05d9\u05bc\u05b9\u05a3\u05d0\u05de\u05b6\u05e8 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u0597\u05d9\u05dd \u05d4\u05b4\u05e0\u05bc\u05b5\u05d4\u05a9 \u05e0\u05b8\u05ea\u05b7\u05a8\u05ea\u05bc\u05b4\u05d9 \u05dc\u05b8\u05db\u05b6\u059c\u05dd \u05d0\u05b6\u05ea\u05be\u05db\u05bc\u05b8\u05dc\u05be\u05e2\u05b5\u05a3\u05e9\u05c2\u05b6\u05d1 \u05c0 \u05d6\u05b9\u05e8\u05b5\u05a3\u05e2\u05b7 \u05d6\u05b6\u0597\u05e8\u05b7\u05e2 \u05d0\u05b2\u05e9\u05c1\u05b6\u05e8\u0599 \u05e2\u05b7\u05dc\u05be\u05e4\u05bc\u05b0\u05e0\u05b5\u05a3\u05d9 \u05db\u05b8\u05dc\u05be\u05d4\u05b8\u05d0\u05b8\u0594\u05e8\u05b6\u05e5 \u05d5\u05b0\u05d0\u05b6\u05ea\u05be\u05db\u05bc\u05b8\u05dc\u05be\u05d4\u05b8\u05e2\u05b5\u059b\u05e5 \u05d0\u05b2\u05e9\u05c1\u05b6\u05e8\u05be\u05d1\u05bc\u05b9\u05a5\u05d5 \u05e4\u05b0\u05e8\u05b4\u05d9\u05be\u05e2\u05b5\u0596\u05e5 \u05d6\u05b9\u05e8\u05b5\u05a3\u05e2\u05b7 \u05d6\u05b8\u0591\u05e8\u05b7\u05e2 \u05dc\u05b8\u05db\u05b6\u05a5\u05dd \u05d9\u05b4\u05bd\u05d4\u05b0\u05d9\u05b6\u0596\u05d4 \u05dc\u05b0\u05d0\u05b8\u05db\u05b0\u05dc\u05b8\u05bd\u05d4\u05c3"}, {"pk": 31, "verse": 30, "text": "\u05d5\u05bc\u05bd\u05dc\u05b0\u05db\u05b8\u05dc\u05be\u05d7\u05b7\u05d9\u05bc\u05b7\u05a3\u05ea \u05d4\u05b8\u05a0\u05d0\u05b8\u05e8\u05b6\u05e5 \u05d5\u05bc\u05dc\u05b0\u05db\u05b8\u05dc\u05be\u05e2\u05b9\u05a8\u05d5\u05e3 \u05d4\u05b7\u05e9\u05c1\u05bc\u05b8\u05de\u05b7\u059c\u05d9\u05b4\u05dd \u05d5\u05bc\u05dc\u05b0\u05db\u05b9\u05a3\u05dc \u05c0 \u05e8\u05b9\u05d5\u05de\u05b5\u05a3\u05e9\u05c2 \u05e2\u05b7\u05dc\u05be\u05d4\u05b8\u05d0\u05b8\u0597\u05e8\u05b6\u05e5 \u05d0\u05b2\u05e9\u05c1\u05b6\u05e8\u05be\u05d1\u05bc\u05b9\u05d5\u0599 \u05e0\u05b6\u05a3\u05e4\u05b6\u05e9\u05c1 \u05d7\u05b7\u05d9\u05bc\u05b8\u0594\u05d4 \u05d0\u05b6\u05ea\u05be\u05db\u05bc\u05b8\u05dc\u05be\u05d9\u05b6\u05a5\u05e8\u05b6\u05e7 \u05e2\u05b5\u0596\u05e9\u05c2\u05b6\u05d1 \u05dc\u05b0\u05d0\u05b8\u05db\u05b0\u05dc\u05b8\u0591\u05d4 \u05d5\u05b7\u05bd\u05d9\u05b0\u05d4\u05b4\u05d9\u05be\u05db\u05b5\u05bd\u05df\u05c3"}, {"pk": 32, "verse": 31, "text": "\u05d5\u05b7\u05d9\u05bc\u05b7\u05a4\u05e8\u05b0\u05d0 \u05d0\u05b1\u05dc\u05b9\u05d4\u05b4\u05d9\u05dd\u0599 \u05d0\u05b6\u05ea\u05be\u05db\u05bc\u05b8\u05dc\u05be\u05d0\u05b2\u05e9\u05c1\u05b6\u05a3\u05e8 \u05e2\u05b8\u05e9\u05c2\u05b8\u0594\u05d4 \u05d5\u05b0\u05d4\u05b4\u05e0\u05bc\u05b5\u05d4\u05be\u05d8\u05b9\u0596\u05d5\u05d1 \u05de\u05b0\u05d0\u05b9\u0591\u05d3 \u05d5\u05bd\u05b7\u05d9\u05b0\u05d4\u05b4\u05d9\u05be\u05e2\u05b6\u05a5\u05e8\u05b6\u05d1 \u05d5\u05bd\u05b7\u05d9\u05b0\u05d4\u05b4\u05d9\u05be\u05d1\u05b9\u0596\u05e7\u05b6\u05e8 \u05d9\u05b9\u05a5\u05d5\u05dd \u05d4\u05b7\u05e9\u05c1\u05bc\u05b4\u05e9\u05c1\u05bc\u05b4\u05bd\u05d9\u05c3  \u05e4"}]
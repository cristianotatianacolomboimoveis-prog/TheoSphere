# ─────────────────────────────────────────────────────────────────────────────
# TheoSphere backend — environment template
#
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# Generate strong secrets locally with:
#   ./scripts/generate-secrets.sh
# or
#   openssl rand -base64 64
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3002
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Database (Supabase or self-hosted Postgres + pgvector + PostGIS) ───────
# DATABASE_URL = pooled connection (used by the application at runtime)
# DIRECT_URL   = direct connection (used by `prisma migrate`)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Vercel Configuration
VERCEL_TOKEN=

# ─── AI providers (at least one required in production) ────────────────────
# Leave blank in development to fall back to the local TF-IDF embedder.
OPENAI_API_KEY=
GEMINI_API_KEY=          # https://aistudio.google.com/apikey

# ─── Cache / Pub-Sub ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ───────────────────────────────────────────────────────────────────
# REQUIRED. Must be ≥ 32 chars. Generate with:
#   openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ─── Observability (optional) ──────────────────────────────────────────────
# When SENTRY_DSN is unset, Sentry calls are silent no-ops.
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
